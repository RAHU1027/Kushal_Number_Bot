    body { 
        background-color: #1a1a1a !important; 
        color: white !important;
        font-family: sans-serif; 
        display: flex; 
        flex-direction: column; 
        align-items: center; 
        padding: 20px; 
        height: 100vh;
        margin: 0;
    }
    .btn { 
        width: 300px; 
        padding: 20px; 
        margin: 10px; 
        border: none; 
        color: white !important; 
        font-weight: bold; 
        cursor: pointer; 
        border-radius: 8px; 
        text-align: center; 
        text-decoration: none;
    }
    .blue { background-color: #3498db !important; }
    .green { background-color: #27ae60 !important; }
